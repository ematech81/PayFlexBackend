# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
BASE_URL=https://api.yourdomain.com

# ============================================
# BILLS PROVIDER SWITCH
# ============================================
BILLS_PROVIDER=vtuafrica

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# DATABASE
# ============================================
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_here

# ============================================
# SMTP Email
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@yourdomain.com

# ============================================
# VTPASS API
# ============================================
VTPASS_ENV=sandbox
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_PUBLIC_KEY=

# ============================================
# KORA PAY
# ============================================
KORA_SECRET_KEY=
KORA_PUBLIC_KEY=
KORA_REDIRECT_URL=https://yourbackend.com/payment/complete

# ============================================
# SENDCHAMP (SMS/OTP)
# ============================================
SENDCHAMP_BASE_URL=https://api.sendchamp.com/api/v1
SENDCHAMP_PUBLIC_KEY=

# ============================================
# VTU AFRICA
# ============================================
VTUAFRICA_MODE=sandbox
VTUAFRICA_SANDBOX_KEY=
VTUAFRICA_LIVE_KEY=
VTUAFRICA_WEBHOOK_URL=https://yourbackend.com/api/vtu-africa/webhook
VTUAFRICA_A2C_PHONE_MTN=
VTUAFRICA_A2C_PHONE_GLO=
VTUAFRICA_A2C_PHONE_AIRTEL=
VTUAFRICA_A2C_PHONE_9MOBILE=
FEATURE_EXAM_PINS_ENABLED=true
FEATURE_BETTING_ENABLED=true

# ============================================
# NIN/BVN Verification
# ============================================
NIN_BVN_API_KEY=

# ============================================
# Travu (transport booking)
# ============================================
TRAVU_API_KEY=
TRAVU_BASE_URL=https://api.travu.africa

# ============================================
# MERPI / Syticks (Bus Tickets, Events, Cinema)
# Portal: https://merpi.syticks.com
# ============================================
MERPI_BASE_URL=https://merpi.syticks.com/api
MERPI_SECRET_KEY=

# ============================================
# CAC VAS (Business Name Registration)
# ============================================
CAC_VAS_BASE_URL=https://vasapp.oasisproducts.ng
CAC_VAS_API_KEY=
CAC_VAS_WEBHOOK_SECRET=
FEATURE_CAC_ENABLED=true
PRICING_CAC_BN_STANDARD=35000
PRICING_CAC_BN_PRIORITY=38000

# ============================================
# Cloudinary (ID document uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
