# ============================================================
# PayFlex Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # development | production

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/payflex?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# ── CORS (comma-separated list of allowed origins) ───────────
# Leave empty to allow all origins in development.
# In production set this to your frontend domain(s).
ALLOWED_ORIGINS=https://payflex.app,https://www.payflex.app

# ── SendChamp SMS (OTP delivery) ──────────────────────────────
# No test credentials — dev mode returns devOtp in API response for UI pre-fill.
SENDCHAMP_BASE_URL=https://api.sendchamp.com/api/v1
SENDCHAMP_PUBLIC_KEY=your_sendchamp_public_key_here

# ── SMTP Email (forgot PIN flow) ──────────────────────────────
# If not set, emails are printed to the console (dev mode).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false              # true for port 465
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@payflex.app

# ── Paystack (wallet top-up) ──────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
# Used for redirect after payment (optional — webview flow handles this in-app)
BASE_URL=https://api.payflex.app

# ── VTPass (airtime, data, electricity, TV, education) ────────
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_PUBLIC_KEY=your_vtpass_public_key
VTPASS_ENV=sandbox             # sandbox | production

# ── VTU Africa (exam pins, airtime2cash, betting) ────────────
VTU_AFRICA_API_KEY=your_vtu_africa_api_key
VTU_AFRICA_ENV=sandbox         # sandbox | production
# Webhook URL VTU Africa will POST transaction status updates to
VTU_AFRICA_WEBHOOK_URL=https://api.payflex.app/api/payment/webhook/vtu-africa

# ── KYC / Identity Verification ──────────────────────────────
# Provider used by service/kycProvider.js — fill in once provider is confirmed
KYC_PROVIDER_BASE_URL=https://api.your-kyc-provider.com
KYC_PROVIDER_API_KEY=your_kyc_api_key

# ── Cloudinary (ID document uploads — optional) ───────────────
# Only needed if you swap multer local storage for Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Travu (bus + flight booking — integration pending) ────────
# Set this once Travu credentials arrive.
# The transport booking endpoint returns 503 until this is set.
TRAVU_API_KEY=
TRAVU_BASE_URL=https://api.travu.africa

# ── Amadeus — DEPRECATED (removal pending) ───────────────────
# These will be removed once the Travu flight replacement is live.
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
